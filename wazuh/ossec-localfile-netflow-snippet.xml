<!--
  ossec-localfile-netflow-snippet.xml
  =====================================
  Wazuh Agent — NetFlow Normalized JSON Log Collection
  Author: Dimas Qi Ramadhani

  DEPLOYMENT:
    Merge this <localfile> block into /var/ossec/etc/ossec.conf
    on the NetFlow collector host (Ubuntu endpoint running Wazuh Agent)
    Then: sudo systemctl restart wazuh-agent

  PERMISSION REQUIREMENT:
    /var/log/netflow/netflow-wazuh.json must be readable by the wazuh user:
      sudo chown root:wazuh /var/log/netflow/netflow-wazuh.json
      sudo chmod 640 /var/log/netflow/netflow-wazuh.json
    Or set directory-level permission:
      sudo chown root:wazuh /var/log/netflow/
      sudo chmod 750 /var/log/netflow/

  NOTES:
    - log_format: json enables native JSON field extraction per log line
    - Wazuh reads new lines appended to this file (inode tracking)
    - Each line in netflow-wazuh.json must be valid JSON (one event per line)
    - rotate_netflow_logs.sh handles log rotation without breaking Wazuh reading
-->

<localfile>
  <log_format>json</log_format>
  <location>/var/log/netflow/netflow-wazuh.json</location>
</localfile>
