<!--
  ossec-localfile-netflow-snippet.xml
  =====================================
  Wazuh Agent — NetFlow Normalized JSON Log Collection
  Author: Dimas Qi Ramadhani

  DEPLOYMENT:
    Tambahkan blok <localfile> ini ke /var/ossec/etc/ossec.conf
    di host collector (Ubuntu dengan Wazuh Agent terpasang),
    sebelum tag </ossec_config> terakhir.
    Lalu: sudo systemctl restart wazuh-agent

  CARA KERJA DI SETUP INI:
    - Normalizer (cron setiap menit) menulis file baru setiap run (mode overwrite)
    - Wazuh Agent mendeteksi perubahan file dan membaca isinya
    - Setiap baris JSON diproses sebagai satu event

  PERMISSION:
    sudo chmod 644 /var/log/netflow/netflow-wazuh.json
    sudo mkdir -p /var/log/netflow
    sudo chmod 755 /var/log/netflow
-->

<localfile>
  <log_format>json</log_format>
  <location>/var/log/netflow/netflow-wazuh.json</location>
</localfile>
