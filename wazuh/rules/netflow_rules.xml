<!--
  netflow_rules.xml
  ==================
  Wazuh Custom Rules — NetFlow Network Anomaly Detection
  Project: Network Flow Monitoring and Anomaly Detection with Wazuh
  Author:  Dimas Qi Ramadhani

  Rule ID Range: 117000 - 117009

  TESTED ON: Wazuh v4.14.5

  DEPLOYMENT:
    sudo cp netflow_rules.xml /var/ossec/etc/rules/
    sudo chown wazuh:wazuh /var/ossec/etc/rules/netflow_rules.xml
    sudo systemctl restart wazuh-manager

  FIELD REFERENCE (nested JSON — use dot notation in rules):
    netflow             - "true" (identifier, used by rule 117000)
    source.ip           - Source IP address
    source.port         - Source port
    destination.ip      - Destination IP address
    destination.port    - Destination port
    flow.protocol       - TCP/UDP/ICMP/IGMP/etc
    flow.direction      - internal_to_internal/internal_to_external/etc
    network.bytes       - Bytes transferred
    network.packets     - Packet count
    event.duration      - Duration in seconds
    tcp.flags           - TCP flags string
    service.name        - DNS/HTTP/HTTPS/SSH/RDP/SMB/WinRM/OTHER
    anomaly.tags        - List of anomaly tags (pre-computed by detect_flow_anomalies.py)
    In dashboard: prefix all fields with data. (e.g. data.source.ip, data.flow.direction)

  FIXES APPLIED:
    - Rule 117000: decoded_as changed to 'json' (built-in), field uses 'source'
    - Rules 117001-117008: field names changed from data.anomaly.tags to anomaly.tags
    - Rule 117004/117006/117007: field names updated to remove data. prefix
    - Rule 117009: if_matched_sid comma-separated list not supported — simplified
    - Rule 117010: description simplified (field substitution not supported in JSON_Decoder)

  NOTES:
    - anomaly.tags pre-computed by detect_flow_anomalies.py
    - MITRE mapping is contextual — flow anomaly != confirmed compromise
    - Validate all rules with wazuh-logtest before deployment
-->

<group name="netflow,network_monitoring,log_management,">

  <!-- ==================================================================
       Rule 117000 — NetFlow Monitoring Base Rule
       Level 0 — anchor rule for all NetFlow events
  -->
  <rule id="117000" level="0">
    <decoded_as>json</decoded_as>
    <field name="netflow">^true$</field>
    <description>NetFlow: Network flow event received from collector</description>
    <group>netflow,network_monitoring,</group>
  </rule>

  <!-- ==================================================================
       Rule 117010 — NetFlow Base Visibility Rule
       Level 3 — low noise catch for any NetFlow event
  -->
  <rule id="117010" level="3">
    <if_sid>117000</if_sid>
    <description>NetFlow: Flow event detected from collector</description>
    <group>netflow,network_monitoring,</group>
  </rule>

  <!-- ==================================================================
       Rule 117001 — Possible Port Scanning Activity
       T1046 — Network Service Discovery
  -->
  <rule id="117001" level="9">
    <if_sid>117000</if_sid>
    <field name="anomaly.tags" type="pcre2">possible_port_scan</field>
    <description>NetFlow: Possible port scanning activity detected — multiple destination ports from one source</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>netflow,network_anomaly,port_scan,network_discovery,</group>
  </rule>

  <!-- ==================================================================
       Rule 117002 — High Outbound Traffic Volume
       T1041 — Exfiltration Over C2 Channel (contextual)
       T1567 — Exfiltration Over Web Service (contextual)
  -->
  <rule id="117002" level="10">
    <if_sid>117000</if_sid>
    <field name="anomaly.tags" type="pcre2">high_outbound_bytes</field>
    <description>NetFlow: High outbound traffic volume detected — possible data exfiltration</description>
    <mitre>
      <id>T1041</id>
      <id>T1567</id>
    </mitre>
    <group>netflow,network_anomaly,high_outbound,possible_exfiltration,</group>
  </rule>

  <!-- ==================================================================
       Rule 117003 — Possible Beaconing Pattern
       T1071 — Application Layer Protocol
  -->
  <rule id="117003" level="10">
    <if_sid>117000</if_sid>
    <field name="anomaly.tags" type="pcre2">possible_beaconing</field>
    <description>NetFlow: Possible beaconing pattern detected — repeated periodic connections to same destination</description>
    <mitre>
      <id>T1071</id>
    </mitre>
    <group>netflow,network_anomaly,beaconing,c2_indicator,</group>
  </rule>

  <!-- ==================================================================
       Rule 117004 — Possible Lateral Movement Flow
       T1021 — Remote Services
  -->
  <rule id="117004" level="10">
    <if_sid>117000</if_sid>
    <field name="flow.direction">^internal_to_internal$</field>
    <field name="destination.port" type="pcre2">^(22|445|3389|5985|5986|1433|3306)$</field>
    <description>NetFlow: Possible lateral movement detected — internal host connecting to admin port on another internal host</description>
    <mitre>
      <id>T1021</id>
      <id>T1021.002</id>
    </mitre>
    <group>netflow,network_anomaly,lateral_movement,east_west,</group>
  </rule>

  <!-- ==================================================================
       Rule 117005 — Suspicious DNS Flow Volume
       T1071.004 — DNS
  -->
  <rule id="117005" level="8">
    <if_sid>117000</if_sid>
    <field name="anomaly.tags" type="pcre2">suspicious_dns_flow</field>
    <description>NetFlow: Suspicious DNS flow volume detected — high UDP/53 traffic from one source</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>netflow,network_anomaly,dns_anomaly,dns_tunneling_indicator,</group>
  </rule>

  <!-- ==================================================================
       Rule 117006 — External Inbound to Sensitive Internal Service
       T1021 — Remote Services (contextual)
  -->
  <rule id="117006" level="9">
    <if_sid>117000</if_sid>
    <field name="flow.direction">^external_to_internal$</field>
    <field name="destination.port" type="pcre2">^(22|23|3389|445|5985|3306|5432|1521|27017|6379)$</field>
    <description>NetFlow: External inbound connection to sensitive internal service detected</description>
    <mitre>
      <id>T1021</id>
    </mitre>
    <group>netflow,network_anomaly,external_inbound,exposed_service,</group>
  </rule>

  <!-- ==================================================================
       Rule 117007 — Internal Host Using Unusual Destination Port
       T1071 — Application Layer Protocol (contextual)
  -->
  <rule id="117007" level="7">
    <if_sid>117000</if_sid>
    <field name="flow.direction">^internal_to_external$</field>
    <field name="destination.port" type="pcre2">^(?!(80|443|8080|8443|53|123|25|587|465|21|22|110|143|993|995|3389|1194|500|4500)$)\d+$</field>
    <description>NetFlow: Internal host using unusual outbound destination port</description>
    <mitre>
      <id>T1071</id>
    </mitre>
    <group>netflow,network_anomaly,unusual_port,</group>
  </rule>

  <!-- ==================================================================
       Rule 117008 — Possible DoS-Like Traffic Pattern
       T1498 — Network Denial of Service
  -->
  <rule id="117008" level="11">
    <if_sid>117000</if_sid>
    <field name="anomaly.tags" type="pcre2">possible_dos_pattern</field>
    <description>NetFlow: Possible DoS-like traffic pattern detected — high packet rate to single destination</description>
    <mitre>
      <id>T1498</id>
    </mitre>
    <group>netflow,network_anomaly,dos_pattern,high_traffic,</group>
  </rule>

  <!-- ==================================================================
       Rule 117009 — Multiple Port Scan Anomalies (Correlation)
       NOTE: if_matched_sid with comma-separated list is NOT supported
       in Wazuh v4.x — use single SID only.
  -->
  <rule id="117009" level="13" frequency="3" timeframe="600">
    <if_matched_sid>117001</if_matched_sid>
    <description>NetFlow: ESCALATE — Multiple port scan anomalies from same source within 10 minutes</description>
    <mitre>
      <id>T1046</id>
    </mitre>
    <group>netflow,network_anomaly,correlation,escalation,</group>
  </rule>

</group>
